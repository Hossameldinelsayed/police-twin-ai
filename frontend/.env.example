# ---- AI Copilot (optional) -------------------------------------------------
# Set OPENAI_API_KEY to enable REAL GPT answers in the AI Copilot.
# Without it, the Copilot automatically uses the built-in deterministic rule
# engine (still fully functional, offline, zero cost).
#
# Get a key at https://platform.openai.com/api-keys
# The key is used ONLY server-side (app/api/ai-copilot/route.ts) and is never
# exposed to the browser.
OPENAI_API_KEY=
# Optional model override (default: gpt-4o-mini - fast & very cheap)
OPENAI_MODEL=gpt-4o-mini
