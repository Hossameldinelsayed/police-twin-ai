# ============================================================================
# Police Twin AI — backend environment configuration
# Copy this file to ".env" and adjust values as needed.
# ============================================================================

# HTTP port the API listens on.
PORT=4000

# PostgreSQL connection string used by both the API (when USE_DB=true) and the
# seed script (db/seed.js). Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:postgres@localhost:5432/police_twin

# When "false" (default) the API serves the deterministic in-memory dataset and
# never touches PostgreSQL — the service runs fully standalone.
# When "true" the API reads from PostgreSQL (run `npm run seed` first).
USE_DB=false

# Comma-separated list of allowed CORS origins. "*" allows any origin (dev).
CORS_ORIGIN=*
